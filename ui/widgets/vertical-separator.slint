import { ColorSettings } from "../theme.slint";

export component VerticalSeparator inherits Path {
    in property <length> size;
    width: 1phx;
    height: size;
    stroke: ColorSettings.grey-200;
    stroke-width: 1phx;
    MoveTo {
        x: 0;
        y: 0;
    }

    LineTo {
        x: 0;
        y: size / 1px;
    }

    Close { }
}
