import { ColorSettings } from "../../settings/colors-settings.slint";

export component HorizontalSeparator inherits Path {
    in property <length> size;
    width: size;
    height: 1phx;
    stroke: ColorSettings.grey-200;
    stroke-width: 1phx;
    MoveTo {
        x: 0;
        y: 0;
    }

    LineTo {
        x: size / 1px;
        y: 0;
    }

    Close { }
}
